# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=dineflow_saas
DATABASE_URL=postgresql://postgres:password@localhost:5432/dineflow_saas

# JWT Configuration
JWT_ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-here
JWT_ACCESS_TOKEN_EXPIRATION_TIME=15m
JWT_REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-here
JWT_REFRESH_TOKEN_EXPIRATION_TIME=7d

# Application Configuration
NODE_ENV=development
PORT=4000
API_PREFIX=api

# OTP Configuration (for customer phone verification)
OTP_EXPIRATION_TIME=300000
OTP_LENGTH=6

# SMS Configuration (Twilio)
SMS_ENABLED=true
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# QR Code Configuration
QR_CODE_BASE_URL=http://localhost:3000
QR_CODE_SIZE=200

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Redis Configuration (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Payment Gateway Configuration
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-api-key
PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret

# Super Admin Configuration
SUPER_ADMIN_EMAIL=admin@kiwiqdine.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# Subscription Configuration
# Set this value for testing (e.g., 2 for 2 days). Leave empty or comment out for production (uses billing cycle logic).
SUBSCRIPTION_TEST_DURATION_DAYS=1
SUBSCRIPTION_INVOICE_TEST_DURATION_DAYS=1